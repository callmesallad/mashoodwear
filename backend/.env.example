# API server
PORT=3001
NODE_ENV=development

# MySQL (use docker-compose or local instance)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mashoodwear
DB_USER=mashoodwear
DB_PASS=mashoodwear_dev

# Auth (phase 6+)
JWT_SECRET=change-me-to-a-random-32-char-string
JWT_EXPIRES_IN=8h

# Uploads
UPLOAD_DIR=./uploads

# Frontend origin for CORS
CORS_ORIGIN=http://localhost:5173

# Production: set TRUST_PROXY=1 behind reverse proxy (nginx) for HTTPS
TRUST_PROXY=0

# Production: public site URL for sitemap.xml (no trailing slash)
SITE_URL=https://shop.example.com
