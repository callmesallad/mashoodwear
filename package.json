{
  "name": "mashoodwear",
  "version": "0.1.0",
  "private": true,
  "description": "Mashhoodwear streetwear storefront",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "migrate": "npm run migrate --prefix backend",
    "seed:images": "npm run seed:images --prefix backend",
    "reset:cms": "npm run reset:cms --prefix backend",
    "build": "npm run build --prefix frontend",
    "test:backend": "npm test --prefix backend",
    "test:unit": "npm run test:unit --prefix backend",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  }
}
